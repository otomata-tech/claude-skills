#!/usr/bin/env bash

# Copy a Claude Code session to another project folder
# Usage: session-copy --session-id <uuid> [--to <path>]

set -euo pipefail

# Detect config dir
if [ -n "${CLAUDE_CONFIG_DIR:-}" ]; then
    CLAUDE_DIR="$CLAUDE_CONFIG_DIR"
else
    CLAUDE_DIR="$HOME/.claude"
fi

PROJECTS_DIR="$CLAUDE_DIR/projects"

SESSION_ID=""
TARGET_PATH=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --session-id) SESSION_ID="$2"; shift 2 ;;
        --to) TARGET_PATH="$2"; shift 2 ;;
        --help|-h)
            echo "Usage: session-copy --session-id <uuid> [--to <path>]"
            echo ""
            echo "Copies a session's .jsonl and subagents dir to a project folder."
            echo ""
            echo "Options:"
            echo "  --session-id <uuid>  Session to copy (required)"
            echo "  --to <path>          Target project directory (default: current directory)"
            exit 0
            ;;
        *) echo "Unknown argument: $1"; exit 1 ;;
    esac
done

if [ -z "$SESSION_ID" ]; then
    echo "Error: --session-id is required"
    exit 1
fi

if [ ! -d "$PROJECTS_DIR" ]; then
    echo "Error: Claude projects directory not found at $PROJECTS_DIR"
    exit 1
fi

# Find the source .jsonl file
SOURCE_FILE=$(find "$PROJECTS_DIR" -name "${SESSION_ID}.jsonl" -type f 2>/dev/null | head -1)

if [ -z "$SOURCE_FILE" ]; then
    echo "Error: Session file not found: ${SESSION_ID}.jsonl"
    exit 1
fi

SOURCE_DIR=$(dirname "$SOURCE_FILE")

# Derive target project folder: from --to or pwd
if [ -n "$TARGET_PATH" ]; then
    DEST_DIR=$(python3 -c "import os; print(os.path.realpath('$TARGET_PATH'))" 2>/dev/null || realpath "$TARGET_PATH" 2>/dev/null || echo "$TARGET_PATH")
    if [ ! -d "$DEST_DIR" ]; then
        echo "Error: Target directory does not exist: $DEST_DIR"
        exit 1
    fi
else
    DEST_DIR=$(python3 -c "import os; print(os.path.realpath('.'))" 2>/dev/null || realpath "$(pwd)" 2>/dev/null || pwd)
fi

ENCODED_PATH=$(echo "$DEST_DIR" | sed 's|[/_]|-|g')
TARGET_DIR="$PROJECTS_DIR/$ENCODED_PATH"

# Guard: refuse if already in the target folder
if [ "$SOURCE_DIR" = "$TARGET_DIR" ]; then
    echo "Error: Session is already in the target project folder"
    echo "  Source: $SOURCE_DIR"
    echo "  Target: $TARGET_DIR"
    exit 1
fi

mkdir -p "$TARGET_DIR"

# Generate a new UUID for the destination copy
NEW_ID=$(uuidgen | tr '[:upper:]' '[:lower:]')

# Copy the .jsonl file, rewriting the sessionId
sed "s/$SESSION_ID/$NEW_ID/g" "$SOURCE_FILE" > "$TARGET_DIR/${NEW_ID}.jsonl"
echo "Copied: ${SESSION_ID}.jsonl -> ${NEW_ID}.jsonl"
echo "  From: $SOURCE_DIR"
echo "  To:   $TARGET_DIR ($DEST_DIR)"

# Copy subagents dir if it exists, rewriting sessionId refs
SUBAGENTS_SOURCE="$SOURCE_DIR/$SESSION_ID"
if [ -d "$SUBAGENTS_SOURCE" ]; then
    cp -r "$SUBAGENTS_SOURCE" "$TARGET_DIR/$NEW_ID"
    find "$TARGET_DIR/$NEW_ID" -type f -name "*.jsonl" -exec sed -i "s/$SESSION_ID/$NEW_ID/g" {} +
    echo "Copied subagents dir: $SESSION_ID/ -> $NEW_ID/"
fi

echo ""
echo "Copy complete."
echo "  cd $DEST_DIR && claude --resume $NEW_ID"
